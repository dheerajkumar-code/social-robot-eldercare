        <trajectory id="0" type="walking">

          <!-- Start: far left, heading right (yaw=0 means +x direction) -->
          <waypoint>
            <time>0.0</time>
            <pose>-4.0 -1.0 0 0 0 0</pose>
          </waypoint>

          <!-- Mid-point: centre, still heading right -->
          <waypoint>
            <time>4.0</time>
            <pose>0.0 -1.0 0 0 0 0</pose>
