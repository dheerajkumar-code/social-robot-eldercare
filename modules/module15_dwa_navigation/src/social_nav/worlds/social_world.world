          <!-- Return: mid-point heading left -->
          <waypoint>
            <time>12.0</time>
            <pose>0.0 -1.0 0 0 0 3.1416</pose>
          </waypoint>

          <!-- Back to start — loop restarts -->
          <waypoint>
