# .env.example
# Copy this to .env and fill in your actual values

# Gemini/Vertex AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PROJECT=your-gcp-project-id
GEMINI_LOCATION=us-central1
GEMINI_MODEL=gemini-audio-v1
GEMINI_API_URL=https://us-central1-aiplatform.googleapis.com/v1/projects/{PROJECT}/locations/{LOCATION}/models/{MODEL}:predict

# Local Services
SPEAKER_SERVICE_URL=http://localhost:8001

# Privacy Mode: local_only | anonymized | full
CLOUD_MODE=anonymized
